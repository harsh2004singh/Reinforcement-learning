   "source": [
    "gamma = 0.9\n",
    "\n",
    "# Example Q calculation\n",
    "def bellman_q(reward, next_value):\n",
    "    return reward + gamma * next_value\n",
    "\n",
    "Q_A = bellman_q(5, 10)\n",
    "Q_B = bellman_q(3, 20)\n",
    "\n",
    "V_opt = max(Q_A, Q_B)\n",
    "\n",
    "print(\"Q(A):\", Q_A)\n",
    "print(\"Q(B):\", Q_B)\n",
    "print(\"Optimal Value:\", V_opt)"
   ]
  },
